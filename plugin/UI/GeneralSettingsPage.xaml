<Page x:Class="revit_mcp_plugin.UI.GeneralSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:revit_mcp_plugin.UI"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="General Settings" FontSize="22" FontWeight="SemiBold" Foreground="#333333"/>
            <TextBlock Text="Configure server and plugin options"
                       Foreground="#666666" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Settings Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Port -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,10,0,10" VerticalAlignment="Center">
                    <TextBlock Text="MCP Server Port" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                    <TextBlock Text="TCP port for Revit-Claude communication (requires restart)"
                               FontSize="11" Foreground="#666666" TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
                <TextBox x:Name="PortTextBox" Grid.Row="0" Grid.Column="1"
                         Margin="15,10,0,10" Padding="8,6" FontSize="14"
                         VerticalAlignment="Center" Width="120" HorizontalAlignment="Left"
                         BorderBrush="#e0e0e0" BorderThickness="1"/>

                <!-- Separator -->
                <Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="0,5" Background="#e0e0e0"/>

                <!-- Log Level -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,10,0,10" VerticalAlignment="Center">
                    <TextBlock Text="Log Level" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                    <TextBlock Text="Verbosity of plugin logging"
                               FontSize="11" Foreground="#666666" Margin="0,3,0,0"/>
                </StackPanel>
                <ComboBox x:Name="LogLevelComboBox" Grid.Row="2" Grid.Column="1"
                          Margin="15,10,0,10" Padding="8,6" FontSize="14"
                          VerticalAlignment="Center" Width="160" HorizontalAlignment="Left"
                          BorderBrush="#e0e0e0" BorderThickness="1">
                    <ComboBoxItem Content="Debug"/>
                    <ComboBoxItem Content="Info"/>
                    <ComboBoxItem Content="Warning"/>
                    <ComboBoxItem Content="Error"/>
                </ComboBox>

                <!-- Separator -->
                <Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0,5" Background="#e0e0e0"/>

                <!-- Plugin Version -->
                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,10,0,10" VerticalAlignment="Center">
                    <TextBlock Text="Plugin Version" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                    <TextBlock Text="Current assembly version"
                               FontSize="11" Foreground="#666666" Margin="0,3,0,0"/>
                </StackPanel>
                <TextBlock x:Name="PluginVersionText" Grid.Row="4" Grid.Column="1"
                           Margin="15,10,0,10" FontSize="14" Foreground="#333333"
                           VerticalAlignment="Center"/>

                <!-- Separator -->
                <Separator Grid.Row="5" Grid.ColumnSpan="2" Margin="0,5" Background="#e0e0e0"/>

                <!-- Revit Version -->
                <StackPanel Grid.Row="6" Grid.Column="0" Margin="0,10,0,10" VerticalAlignment="Center">
                    <TextBlock Text="Revit Version" FontSize="14" FontWeight="SemiBold" Foreground="#333333"/>
                    <TextBlock Text="Current Revit version year"
                               FontSize="11" Foreground="#666666" Margin="0,3,0,0"/>
                </StackPanel>
                <TextBlock x:Name="RevitVersionText" Grid.Row="6" Grid.Column="1"
                           Margin="15,10,0,10" FontSize="14" Foreground="#333333"
                           VerticalAlignment="Center"/>
            </Grid>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="ResetDefaultsButton" Content="Reset Defaults"
                    Padding="15,8" Margin="0,0,10,0" FontSize="13"
                    Background="#f5f5f5" Foreground="#333333" BorderBrush="#e0e0e0"
                    Click="ResetDefaultsButton_Click" Cursor="Hand"/>
            <Button x:Name="SaveButton" Content="Save"
                    Padding="20,8" FontSize="13"
                    Background="#2196F3" Foreground="White" BorderBrush="#1976D2"
                    Click="SaveButton_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Page>
